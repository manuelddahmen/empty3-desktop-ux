package one.empty3.library.core.testing.jvm;

import com.google.cloud.storage.BlobId;
import com.google.cloud.storage.BlobInfo;
import com.google.cloud.storage.Storage;
import com.google.cloud.storage.StorageOptions;
import one.empty3.libs.Image;

import javax.imageio.ImageIO;
import java.awt.image.RenderedImage;
import java.io.ByteArrayOutputStream;
import java.io.File;
import java.io.FileOutputStream;
import java.io.IOException;
import java.nio.file.Paths;
import java.util.logging.Level;
import java.util.logging.Logger;

/**
 * Extension de TestObjet capable d'enregistrer les sorties dans Google Cloud Storage.
 */
public abstract class CloudStorageTestObjet extends TestObjet {
    private static final Logger logger = Logger.getLogger(CloudStorageTestObjet.class.getName());
    private String bucketName;
    private Storage storage;

    public CloudStorageTestObjet() {
        super();
        initGCS();
    }

    private void initGCS() {
        this.bucketName = System.getenv("GCS_BUCKET_NAME");
        if (this.bucketName == null) {
            this.bucketName = System.getProperty("gcs.bucket.name", "empty3-cloud-run-output");
        }
        try {
            this.storage = StorageOptions.getDefaultInstance().getService();
        } catch (Exception e) {
            logger.log(Level.WARNING, "Impossible d'initialiser Google Cloud Storage. Les fichiers seront enregistrés localement uniquement.", e);
        }
    }

    public void setBucketName(String bucketName) {
        this.bucketName = bucketName;
    }

    @Override
    protected void ecrireImage(RenderedImage ri, String type, File fichier) {
        // Appel de la méthode parente pour l'enregistrement local (si nécessaire)
        super.ecrireImage(ri, type, fichier);

        if (storage != null && bucketName != null) {
            try {
                ByteArrayOutputStream baos = new ByteArrayOutputStream();
                ImageIO.write(ri, type, baos);
                byte[] bytes = baos.toByteArray();

                String blobName = "output/" + sousdossier + "/" + fichier.getName();
                BlobId blobId = BlobId.of(bucketName, blobName);
                BlobInfo blobInfo = BlobInfo.newBuilder(blobId).setContentType("image/" + type.toLowerCase()).build();
                
                storage.create(blobInfo, bytes);
                logger.info("Image uploadée vers GCS: gs://" + bucketName + "/" + blobName);
            } catch (IOException e) {
                logger.log(Level.SEVERE, "Erreur lors de l'upload de l'image vers GCS", e);
            }
        }
    }

    // On pourrait aussi surcharger d'autres méthodes si TestObjet en avait pour d'autres types de fichiers.
    // Pour l'instant on se concentre sur ecrireImage qui est utilisée dans run().
    
    public void uploadFile(File file, String remotePath) {
        if (storage != null && bucketName != null && file.exists()) {
            try {
                BlobId blobId = BlobId.of(bucketName, remotePath);
                BlobInfo blobInfo = BlobInfo.newBuilder(blobId).build();
                storage.createFrom(blobInfo, Paths.get(file.getAbsolutePath()));
                logger.info("Fichier uploadé vers GCS: gs://" + bucketName + "/" + remotePath);
            } catch (IOException e) {
                logger.log(Level.SEVERE, "Erreur lors de l'upload du fichier vers GCS: " + file.getAbsolutePath(), e);
            }
        }
    }
}
